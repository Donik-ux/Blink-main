# Скопируй в client/.env и заполни

# Локально для разработки
VITE_API_URL=http://localhost:5000
VITE_SOCKET_URL=http://localhost:5000

# Для production (после деплоя бэкенда на Render):
# VITE_API_URL=https://blink-server.onrender.com
# VITE_SOCKET_URL=https://blink-server.onrender.com

# Google OAuth Client ID (Web application)
# https://console.cloud.google.com → APIs & Services → Credentials
# Должен совпадать с GOOGLE_CLIENT_ID на сервере.
VITE_GOOGLE_CLIENT_ID=

# Sentry DSN (опционально)
# VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# HTTPS в dev (для Service Worker / Push на телефоне)
# VITE_HTTPS=1
