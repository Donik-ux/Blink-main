# Скопируй в server/.env и заполни своими значениями

PORT=5000
NODE_ENV=production

# MongoDB Atlas — https://cloud.mongodb.com (бесплатно 512MB)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.example.mongodb.net/blink?retryWrites=true&w=majority

# Redis — опционально. Бесплатно: https://upstash.com
REDIS_URL=redis://localhost:6379

# JWT секреты — сгенерируй случайные строки минимум 32 символа
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_me_to_random_string_32_chars_min
JWT_REFRESH_SECRET=change_me_to_another_random_string_32

# CORS — домен фронтенда (для production)
# CLIENT_URL=https://blink.vercel.app

# Web Push (VAPID). Сгенерируй пары ключей:
# npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# Google OAuth — https://console.cloud.google.com → APIs & Services → Credentials
# OAuth 2.0 Client ID (Web application). Добавь Authorized JavaScript origin = твой CLIENT_URL.
GOOGLE_CLIENT_ID=

# SMTP для писем (сброс пароля, подтверждение email)
# Если SMTP_HOST не задан — письма пишутся в консоль (dev режим).
# Примеры:
#   Gmail App Password: SMTP_HOST=smtp.gmail.com SMTP_PORT=587
#   SendGrid:           SMTP_HOST=smtp.sendgrid.net SMTP_PORT=587 SMTP_USER=apikey SMTP_PASS=<key>
#   Resend:             SMTP_HOST=smtp.resend.com SMTP_PORT=465 SMTP_USER=resend SMTP_PASS=<key>
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Blink <noreply@blink.app>
